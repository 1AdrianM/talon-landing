---
const values = [
  { title: 'Price Change Detection', desc: 'Get instant alerts when competitors adjust prices.' },
  { title: 'Market Signals', desc: 'Understand the context behind price movements.' },
  { title: 'Webhooks', desc: 'Receive real-time notifications to your endpoints.' },
  { title: 'Price History', desc: 'Access historical data to analyze trends over time.' },
  { title: 'Works with any page', desc: 'No API access needed. Just pass a URL.' },
  { title: 'Developer-first API', desc: 'Simple REST endpoints with clear responses.' }
];

const steps = [
  { num: '01', title: 'Add product URL', desc: 'Send us any product page URL you want to track.' },
  { num: '02', title: 'Talon monitors automatically', desc: 'We check prices at intervals you configure.' },
  { num: '03', title: 'Get signals via API or webhooks', desc: 'Receive price changes, trends, and market context.' }
];

const trackRequest = `POST /products/track-product

{
  "url": "https://competitor.com/product/123",
  "selector": ".price"
}`;

const apiResponse = `{
  "price": 1299.00,
  "previous": 1399.00,
  "changed": true,
  "signal": "price_drop",
  "trend": "falling"
}`;

const jsCodePreview = `const response = await fetch("https://price-tracking-api.p.rapidapi.com/track-product", {
  method: "POST",
  headers: {
    "X-RapidAPI-Key": "YOUR_API_KEY",
    "X-RapidAPI-Host": "price-tracking-api.p.rapidapi.com",
    "Content-Type": "application/json"
  },
  body: JSON.stringify({
    "url": "https://competitor.com/product/123",
    "selector": ".price"
  })
});

const data = await response.json();
// { "price": 1299.00, "signal": "price_drop" }`;
