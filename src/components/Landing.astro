<script>
// Demo uses internal backend without auth
const DEMO_URL = 'https://api-talon.fly.dev/demo';

document.addEventListener('DOMContentLoaded', () => {
  const btn = document.getElementById('extract-btn');
  const urlInput = document.getElementById('product-url');
  const selectorInput = document.getElementById('selector');
  const output = document.getElementById('result-output');
  
  if (!btn || !urlInput || !selectorInput || !output) return;
  
  btn.addEventListener('click', async () => {
    const url = urlInput.value.trim();
    const selector = selectorInput.value.trim() || '.price';
    
    if (!url) {
      output.innerHTML = '<code class="error">Please enter a product URL</code>';
      return;
    }
    
    btn.disabled = true;
    btn.textContent = 'Testing...';
    output.innerHTML = '<code class="loading">Testing price extraction...</code>';
    
    try {
      const response = await fetch(`${DEMO_URL}/track-product`, {
        method: 'POST',
        headers: {
          'X-Api-Key': 'demo_test_2024',
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          url: url,
          selector: selector
        })
      });
      
      const data = await response.json();
      
      if (response.ok) {
        output.innerHTML = '<code>' + JSON.stringify(data, null, 2) + '</code>';
      } else {
        output.innerHTML = '<code class="error">' + JSON.stringify(data, null, 2) + '</code>';
      }
    } catch (err) {
      output.innerHTML = '<code class="error">Could not connect to API: ' + err.message + '</code>';
    }
    
    btn.disabled = false;
    btn.textContent = 'Test Price Extraction';
  });
});
</script>

